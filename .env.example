# ─────────────────────────────────────────────────────────────
#  Automatarr — Environment Variables
#  Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

PORT=3000
BACKEND_PORT=8000
SECRET_KEY=change-this-to-a-random-string

PUID=1000
PGID=1000
TZ=America/New_York

# ── Media paths (host machine) ─────────────────────────────
MOVIES_PATH=/media/movies
SHOWS_PATH=/media/shows
MUSIC_PATH=/media/music
BOOKS_PATH=/media/books
DOWNLOADS_PATH=/media/downloads

# ── Zurg + rclone (--profile zurg) ────────────────────────
ZURG_PORT=9999
RCLONE_CACHE_SIZE=10G

# ── Plex (--profile plex) ─────────────────────────────────
# Get claim token at https://www.plex.tv/claim (expires in 4 min)
PLEX_CLAIM=

# ── Jellyfin (--profile jellyfin) ─────────────────────────
JELLYFIN_PORT=8096

# ── Zilean (--profile zilean) ──────────────────────────────
ZILEAN_PORT=8182

# ── Arr apps (--profile radarr/sonarr/arrs/etc.) ──────────
RADARR_PORT=7878
SONARR_PORT=8989
PROWLARR_PORT=9696
LIDARR_PORT=8686
READARR_PORT=8787
BAZARR_PORT=6767
OVERSEERR_PORT=5055
WHISPARR_PORT=6969
