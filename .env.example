# ─────────────────────────────────────────────────────────────
#  Automatarr — Environment Variables
#
#  Usage:
#    cp .env.example .env
#    # edit .env with your values
#    docker-compose up -d
#
#  Or run the guided installer:
#    ./install.sh
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
# UI port (access Automatarr at http://localhost:PORT)
PORT=3000

# Backend API port (OpenAPI docs at http://localhost:BACKEND_PORT/docs)
BACKEND_PORT=8000

# Random secret key for the backend session/auth.
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-string

# Allowed CORS origins for the API (comma-separated, no spaces).
# Leave blank to allow all origins (suitable for local/LAN-only installs).
# Example for reverse-proxy: CORS_ORIGINS=https://automatarr.yourdomain.com
CORS_ORIGINS=

# ── System ────────────────────────────────────────────────────
# Your user ID and group ID (run 'id -u' and 'id -g' to find them)
PUID=1000
PGID=1000

# Your timezone in IANA format. Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# ── Media Library Paths ───────────────────────────────────────
# Absolute paths on the HOST machine where symlinks will be created.
# These directories will be mounted read/write into the backend container.
MOVIES_PATH=/media/movies
SHOWS_PATH=/media/shows
MUSIC_PATH=/media/music      # only needed with --profile lidarr/arrs
BOOKS_PATH=/media/books      # only needed with --profile readarr/arrs
DOWNLOADS_PATH=/media/downloads

# ── Zurg + rclone  (--profile zurg) ──────────────────────────
# Required for symlink mode — mounts your Real-Debrid library via WebDAV.
# The RD API key goes in zurg/config.yml  (or the installer sets it for you).
ZURG_PORT=9999

# VFS cache size for rclone — increase if you stream many files simultaneously.
# Examples: 10G (default), 20G, 50G
RCLONE_CACHE_SIZE=10G

# ── Plex  (--profile plex) ────────────────────────────────────
# Get a 4-minute claim token at: https://www.plex.tv/claim/
# Leave blank if you'll set up Plex manually later.
PLEX_CLAIM=

# ── Media Servers ─────────────────────────────────────────────
JELLYFIN_PORT=8096           # --profile jellyfin
EMBY_PORT=8920               # (if you add Emby to docker-compose later)

# ── Indexers ──────────────────────────────────────────────────
# Zilean is a self-hosted alternative to the hosted Torrentio indexer.
ZILEAN_PORT=8182              # --profile zilean

# ── *Arr Apps  (--profile radarr|sonarr|arrs|…) ──────────────
RADARR_PORT=7878
SONARR_PORT=8989
PROWLARR_PORT=9696
LIDARR_PORT=8686
READARR_PORT=8787
BAZARR_PORT=6767
OVERSEERR_PORT=5055
WHISPARR_PORT=6969
